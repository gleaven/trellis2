# ───────────────────────────────────────────────────────────────────
# HuggingFace token. Required at first run to download TRELLIS.2 weights
# and the RMBG-2.0 background remover (~10 GB total).
# Generate at https://huggingface.co/settings/tokens with read access.
# ───────────────────────────────────────────────────────────────────
HF_TOKEN=

# ───────────────────────────────────────────────────────────────────
# Host port mapping. The wrapper FastAPI server listens here; Gradio is
# proxied internally on port 7860.
# ───────────────────────────────────────────────────────────────────
APP_PORT=8080

# ───────────────────────────────────────────────────────────────────
# Build-time / runtime tunables.
#   TORCH_CUDA_ARCH_LIST — set to your GPU's compute capability.
#                          12.1 = GB10 Blackwell. 9.0 = H100. 8.9 = L40S/4090.
#   GRADIO_ROOT_PATH      — leave default unless reverse-proxying under
#                          a different prefix.
# ───────────────────────────────────────────────────────────────────
TORCH_CUDA_ARCH_LIST=12.1
GRADIO_ROOT_PATH=/trellis2/gradio

# ───────────────────────────────────────────────────────────────────
# Optional ServiceRouter integration (if running alongside servicerouter).
# Leave unset for standalone use — the app no-ops GPU-stats lookups.
# ───────────────────────────────────────────────────────────────────
# SERVICEROUTER_URL=http://demo-servicerouter:8080

# ───────────────────────────────────────────────────────────────────
# Optional HTTPS reverse proxy (--profile proxy).
# ───────────────────────────────────────────────────────────────────
DEMO_HOSTNAME=localhost
HTTP_PORT=8081
HTTPS_PORT=8443
